# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here  # get via @userinfobot

# Strava
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:8080/callback  # must match your Strava app settings

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (optional — defaults to coach.db in project root)
# DATABASE_PATH=/data/coach.db
